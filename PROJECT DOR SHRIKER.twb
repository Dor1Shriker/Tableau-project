      <column caption='Pledge Containers' datatype='string' name='[Calculation_384213359561080837]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Pledged Amount USD] &lt;= 500 THEN &quot;0-500&quot;&#13;&#10;ELSEIF [Pledged Amount USD] &lt;= 1000 THEN &quot;500-1,000&quot;&#13;&#10;ELSEIF [Pledged Amount USD] &lt;= 3000 THEN &quot;1,000-3,000&quot;&#13;&#10;ELSEIF [Pledged Amount USD] &lt;= 5000 THEN &quot;3,000-5,000&quot;&#13;&#10;ELSEIF [Pledged Amount USD] &lt;= 10000 THEN &quot;5,000-10,000&quot;&#13;&#10;ELSE &quot;more than 10,000&quot;&#13;&#10;END' />
      </column>
